<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BivLauncher.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="BivLauncher.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding ProductName}"
        Width="1240"
        Height="780"
        MinWidth="1040"
        MinHeight="680">

  <Grid>
    <Border Background="{Binding LauncherBackgroundBrush}" />
    <Image Source="{Binding BrandingBackgroundImage}"
           Stretch="UniformToFill"
           IsVisible="{Binding HasBrandingBackgroundImage}" />
    <Border Background="#FF000000"
            Opacity="{Binding BrandingBackgroundOverlayOpacity}"
            IsVisible="{Binding HasBrandingBackgroundImage}" />

    <Grid Margin="18">
      <Grid>
        <Border Classes="loginCard"
                Width="{Binding LoginCardWidth}"
                HorizontalAlignment="{Binding LoginCardHorizontalAlignment}"
                VerticalAlignment="Center"
                Margin="24,0"
                Background="{Binding LoginCardBackgroundBrush}"
                BorderBrush="{Binding LoginCardBorderBrush}"
                IsVisible="{Binding IsLoginRequired}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
            <TextBlock Classes="sectionTitle"
                       Foreground="{Binding PrimaryTextBrush}"
                       Text="{Binding AccountHeaderText}" />
            <TextBlock Grid.Row="1"
                       Classes="subtle"
                       Foreground="{Binding SecondaryTextBrush}"
                       Text="{Binding StatusText}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="2"
                       Foreground="{Binding PrimaryTextBrush}"
                       Text="{Binding SavedAccountsLabelText}"
                       IsVisible="{Binding HasStoredAccounts}" />
            <ComboBox Grid.Row="3"
                      Background="{Binding InputBackgroundBrush}"
                      BorderBrush="{Binding InputBorderBrush}"
                      Foreground="{Binding InputForegroundBrush}"
                      ItemsSource="{Binding StoredPlayerAccounts}"
                      SelectedItem="{Binding SelectedStoredAccount}"
                      IsVisible="{Binding HasStoredAccounts}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Username}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Row="4"
                    Content="{Binding DeleteAccountButtonText}"
                    Command="{Binding DeleteAccountCommand}"
                    IsVisible="{Binding HasStoredAccounts}" />

            <TextBlock Grid.Row="5"
                       Foreground="{Binding PrimaryTextBrush}"
                       Text="{Binding UsernameLabelText}" />
            <TextBox Grid.Row="6"
                     Watermark="Player"
                     Background="{Binding InputBackgroundBrush}"
                     BorderBrush="{Binding InputBorderBrush}"
                     Foreground="{Binding InputForegroundBrush}"
                     Text="{Binding PlayerUsername}" />

            <TextBlock Grid.Row="7"
                       Foreground="{Binding PrimaryTextBrush}"
                       Text="{Binding PasswordLabelText}" />
            <TextBox Grid.Row="8"
                     Background="{Binding InputBackgroundBrush}"
                     BorderBrush="{Binding InputBorderBrush}"
                     Foreground="{Binding InputForegroundBrush}"
                     Text="{Binding PlayerPassword}"
                     PasswordChar="*" />
            <Button Grid.Row="9"
                    Classes="playButton"
                    Content="{Binding LoginButtonText}"
                    Command="{Binding LoginCommand}" />

            <TextBlock Grid.Row="10"
                       Foreground="{Binding PrimaryTextBrush}"
                       Text="{Binding TwoFactorCodeLabelText}"
                       IsVisible="{Binding IsTwoFactorStepActive}" />
            <TextBox Grid.Row="11"
                     Watermark="123456"
                     MaxLength="6"
                     Background="{Binding InputBackgroundBrush}"
                     BorderBrush="{Binding InputBorderBrush}"
                     Foreground="{Binding InputForegroundBrush}"
                     Text="{Binding PlayerTwoFactorCode}"
                     IsVisible="{Binding IsTwoFactorStepActive}" />
            <TextBlock Grid.Row="12"
                       Classes="subtle"
                       Foreground="{Binding SecondaryTextBrush}"
                       Text="{Binding TwoFactorHintText}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding IsTwoFactorStepActive}" />
          </Grid>
        </Border>

        <Grid IsVisible="{Binding IsLauncherReady}"
              ColumnDefinitions="*,392"
              ColumnSpacing="16">
          <Border Classes="featurePanel">
            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Classes="subtle"
                           Foreground="{Binding SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           Text="{Binding LauncherHeaderStatusText}"
                           IsVisible="{Binding HasLauncherHeaderStatusText}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Classes="toolbarIconButton"
                        Command="{Binding RefreshCommand}">
                  <TextBlock Text="&#x21BB;"
                             FontSize="16"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        Classes="toolbarIconButton"
                        Command="{Binding ToggleSettingsCommand}">
                  <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                </Button>
              </Grid>
              <Border Grid.Row="1"
                      Classes="syncCard"
                      IsVisible="{Binding IsFileSyncInProgress}">
                <StackPanel Spacing="7">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Foreground="{Binding PrimaryTextBrush}"
                               FontWeight="SemiBold"
                               Text="{Binding FileSyncStageText}" />
                    <TextBlock Grid.Column="1"
                               Foreground="{Binding PrimaryTextBrush}"
                               Text="{Binding FileSyncPercentText}" />
                  </Grid>
                  <ProgressBar Minimum="0"
                               Maximum="100"
                               Height="8"
                               Value="{Binding FileSyncProgressPercent}" />
                  <TextBlock Classes="subtle"
                             Foreground="{Binding SecondaryTextBrush}"
                             Text="{Binding FileSyncSummaryText}" />
                  <TextBlock Classes="subtle"
                             Foreground="{Binding SecondaryTextBrush}"
                             Text="{Binding FileSyncCurrentFileText}"
                             TextWrapping="Wrap"
                             MaxHeight="36" />
                </StackPanel>
              </Border>

              <Grid Grid.Row="2"
                    RowDefinitions="*,Auto"
                    RowSpacing="14">
                <Border Classes="panel heroPanel">
                  <Grid>
                    <Grid RowDefinitions="Auto,Auto,*"
                          RowSpacing="10"
                          IsVisible="{Binding HasSelectedNews}">
                      <TextBlock Classes="heroMeta"
                                 Foreground="{Binding SecondaryTextBrush}"
                                 Text="{Binding SelectedNewsMetaText}" />
                      <TextBlock Grid.Row="1"
                                 FontSize="24"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding PrimaryTextBrush}"
                                 Text="{Binding SelectedNewsHeadlineText}"
                                 TextWrapping="Wrap" />
                      <ScrollViewer Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Foreground="{Binding PrimaryTextBrush}"
                                   Text="{Binding SelectedNewsBodyText}"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                      </ScrollViewer>
                    </Grid>

                    <Grid IsVisible="{Binding HasSelectedNewsPlaceholder}" />
                  </Grid>
                </Border>

                <Border Grid.Row="1"
                        Classes="panel newsRailPanel"
                        IsVisible="{Binding HasSelectedNews}">
                  <ListBox Classes="newsRailList"
                           ItemsSource="{Binding NewsItems}"
                           SelectedItem="{Binding SelectedNewsItem}">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="newsMiniCard">
                          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1"
                                       Classes="subtle"
                                       Opacity="0.84"
                                       Text="{Binding Meta}"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2"
                                       Opacity="0.84"
                                       Text="{Binding Preview}"
                                       TextWrapping="Wrap"
                                       MaxHeight="54" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>
              </Grid>

              <StackPanel Grid.Row="3"
                          Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Bottom">
                <Button Classes="playButton"
                        Content="{Binding PlayButtonText}"
                        Command="{Binding LaunchCommand}" />
                <Button Classes="secondaryActionButton"
                        Content="{Binding VerifyFilesButtonText}"
                        Command="{Binding VerifyFilesCommand}" />
                <Button Classes="secondaryActionButton"
                        Content="{Binding OpenLogsFolderButtonText}"
                        Command="{Binding OpenLogsFolderCommand}" />
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="14">
            <Border Classes="panel accountCornerPanel">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="14">
                  <Border Classes="accountAvatar">
                    <TextBlock Text="&#xE77B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{Binding PrimaryTextBrush}"
                               Text="{Binding AccountPanelTitle}" />
                    <TextBlock Classes="subtle"
                               Foreground="{Binding SecondaryTextBrush}"
                               Text="{Binding AccountPanelSubtitle}"
                               IsVisible="{Binding HasAccountPanelSubtitle}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Classes="adminRoleBanner"
                        IsVisible="{Binding HasAdminRoleBanner}">
                  <TextBlock Classes="adminRoleBannerText"
                             Text="{Binding AdminRoleBannerText}" />
                </Border>

                <ComboBox Grid.Row="2"
                          Classes="accountSelect"
                          ItemsSource="{Binding StoredPlayerAccounts}"
                          SelectedItem="{Binding SelectedStoredAccount}"
                          IsVisible="{Binding HasMultipleStoredAccounts}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Username}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Grid.Row="3"
                      ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="8">
                  <Button Classes="accountActionButton"
                          Content="{Binding AddAccountButtonText}"
                          Command="{Binding AddAccountCommand}" />
                  <Button Grid.Column="1"
                          Classes="accountActionButton"
                          Content="{Binding DeleteAccountButtonText}"
                          Command="{Binding DeleteAccountCommand}"
                          IsVisible="{Binding HasStoredAccounts}" />
                  <Button Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Classes="secondaryActionButton"
                          Content="{Binding LogoutButtonText}"
                          Command="{Binding LogoutCommand}" />
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="panel serverShelfPanel">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*">
                  <TextBlock Classes="sectionTitle"
                             Foreground="{Binding PrimaryTextBrush}"
                             Text="{Binding ServersHeaderText}" />
                </Grid>
                <ListBox Grid.Row="1"
                         Classes="serverShelfList"
                         ItemsSource="{Binding ManagedServers}"
                         SelectedItem="{Binding SelectedServer}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="serverListCard">
                        <Grid ColumnDefinitions="72,*" ColumnSpacing="14">
                          <Border Classes="serverIconWrap">
                            <Image Source="{Binding Icon}" Stretch="UniformToFill" />
                          </Border>
                          <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                              <Ellipse Width="9"
                                       Height="9"
                                       VerticalAlignment="Center"
                                       Fill="{Binding OnlineStatusBrush}" />
                              <TextBlock Classes="subtle"
                                         VerticalAlignment="Center"
                                         Text="{Binding OnlineStatusText}" />
                            </StackPanel>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

          </Grid>
        </Grid>

        <Border IsVisible="{Binding IsSettingsOpen}"
                Background="#C0050811">
          <Grid>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="640"
                    MaxWidth="880"
                    MaxHeight="700"
                    Padding="18"
                    CornerRadius="18"
                    BorderThickness="1">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="sectionTitle"
                             Foreground="{Binding PrimaryTextBrush}"
                             Text="{Binding SettingsHeaderText}" />
                  <Button Grid.Column="1"
                          Classes="iconButton"
                          Command="{Binding CloseSettingsCommand}">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" />
                  </Button>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Spacing="12" Margin="0,0,4,0">
                    <Border Classes="panel">
                      <StackPanel Spacing="10">
                        <TextBlock Classes="sectionTitle"
                                   Foreground="{Binding PrimaryTextBrush}"
                                   Text="{Binding SettingsHeaderText}" />
                        <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="{Binding LanguageLabelText}" />
                        <ComboBox Background="{Binding InputBackgroundBrush}"
                                  BorderBrush="{Binding InputBorderBrush}"
                                  Foreground="{Binding InputForegroundBrush}"
                                  ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption}" />
                        <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="{Binding JavaModeLabelText}" />
                        <ComboBox Background="{Binding InputBackgroundBrush}"
                                  BorderBrush="{Binding InputBorderBrush}"
                                  Foreground="{Binding InputForegroundBrush}"
                                  ItemsSource="{Binding JavaModeOptions}"
                                  SelectedItem="{Binding SelectedJavaModeOption}" />
                        <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="{Binding RamLabelText}" />
                        <Grid ColumnDefinitions="*,120" ColumnSpacing="10">
                          <Slider Minimum="{Binding RamMinMb}"
                                  Maximum="{Binding RamMaxMb}"
                                  TickFrequency="256"
                                  IsSnapToTickEnabled="True"
                                  Value="{Binding RamMb}" />
                          <TextBox Grid.Column="1"
                                   Text="{Binding RamMb}"
                                   Background="{Binding InputBackgroundBrush}"
                                   BorderBrush="{Binding InputBorderBrush}"
                                   Foreground="{Binding InputForegroundBrush}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                          <TextBlock Classes="subtle"
                                     Foreground="{Binding SecondaryTextBrush}"
                                     Text="{Binding RamMinText}" />
                          <TextBlock Grid.Column="1"
                                     HorizontalAlignment="Right"
                                     Classes="subtle"
                                     Foreground="{Binding SecondaryTextBrush}"
                                     Text="{Binding RamMaxText}" />
                        </Grid>
                        <Button Content="{Binding SaveSettingsButtonText}"
                                Command="{Binding SaveSettingsCommand}" />
                      </StackPanel>
                    </Border>

                    <Border Classes="panel">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle"
                                   Foreground="{Binding PrimaryTextBrush}"
                                   Text="{Binding UpdateHeaderText}" />
                        <TextBlock Classes="subtle"
                                   Foreground="{Binding SecondaryTextBrush}"
                                   Text="{Binding CurrentVersionText}" />
                        <TextBlock Classes="subtle"
                                   Foreground="{Binding SecondaryTextBrush}"
                                   Text="{Binding LatestVersionText}" />
                        <TextBlock Classes="subtle"
                                   Foreground="{Binding SecondaryTextBrush}"
                                   Text="{Binding UpdateAvailabilityText}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Button Content="{Binding DownloadUpdateButtonText}"
                                  Command="{Binding DownloadUpdateCommand}"
                                  IsVisible="{Binding IsUpdateAvailable}" />
                          <Button Classes="playButton"
                                  Content="{Binding InstallUpdateButtonText}"
                                  Command="{Binding InstallUpdateCommand}"
                                  IsVisible="{Binding IsUpdateAvailable}" />
                        </StackPanel>
                        <Button Content="{Binding OpenUpdateButtonText}"
                                Command="{Binding OpenUpdateUrlCommand}"
                                IsVisible="{Binding IsUpdateAvailable}" />
                        <TextBlock Classes="subtle"
                                   Foreground="{Binding SecondaryTextBrush}"
                                   Text="{Binding UpdateDownloadProgressText}"
                                   TextWrapping="Wrap" />
                        <TextBox Text="{Binding UpdateReleaseNotes}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 Background="{Binding InputBackgroundBrush}"
                                 BorderBrush="{Binding InputBorderBrush}"
                                 Foreground="{Binding InputForegroundBrush}"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 IsVisible="{Binding HasUpdateReleaseNotes}"
                                 Height="90" />
                        <Button Content="{Binding OpenLogsFolderButtonText}"
                                Command="{Binding OpenLogsFolderCommand}" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border IsVisible="{Binding IsBanNoticeVisible}"
                Background="#B5070C12">
          <Grid>
            <Border Classes="banNoticeCard"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="560"
                    MaxWidth="640">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="18">
                <Border Classes="banNoticeGlyph">
                  <TextBlock Text="!"
                             FontSize="28"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="#FFF7F3" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="12">
                  <Border Classes="banNoticePill">
                    <TextBlock Text="{Binding BanNoticeEyebrowText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               LetterSpacing="1.5"
                               Foreground="#FFDCCF" />
                  </Border>

                  <TextBlock Classes="sectionTitle"
                             Text="{Binding BanNoticeTitle}"
                             Foreground="{Binding PrimaryTextBrush}"
                             TextWrapping="Wrap" />

                  <TextBlock Classes="banNoticeMessage"
                             Text="{Binding BanNoticeMessage}"
                             Foreground="{Binding PrimaryTextBrush}"
                             TextWrapping="Wrap" />

                  <Button Classes="banNoticeButton"
                          Content="{Binding BanNoticeDismissButtonText}"
                          Command="{Binding DismissBanNoticeCommand}" />
                </StackPanel>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
