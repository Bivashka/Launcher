<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BivLauncher.Client.App"
             xmlns:local="using:BivLauncher.Client"
             RequestedThemeVariant="Dark">
             <!-- Launcher stays on the dark theme regardless of the system theme variant. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://BivLauncher.Client/Themes/DefaultTheme.axaml" />
    </Application.Styles>
</Application>
